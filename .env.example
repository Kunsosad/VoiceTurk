# ============================================================
# VoiceTurk MVP Environment
# ============================================================

APP_ENV=development
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# ============================================================
# Database
# MVP default should work locally without external services.
# Codex may upgrade to Postgres later, but must keep local fallback.
# ============================================================

DATABASE_URL=sqlite:///./voiceturk.db

# ============================================================
# Provider Switches
# External integrations must go through ports/adapters.
# The MVP must run even when Agora/Solana/S3/ASR/LLM/Redis are disabled.
# ============================================================

OBJECT_STORAGE_PROVIDER=local
REALTIME_PROVIDER=browser_tts
ALLOW_COACH_FALLBACK=false
PROOF_PROVIDER=local_hash
FAST_CHECK_PROVIDER=rule_based
DEEP_CHECK_PROVIDER=mock
ASR_PROVIDER=mock
LLM_FEEDBACK_PROVIDER=template
QUEUE_PROVIDER=in_process
KEEP_FAILED_UPLOADS=false

# ============================================================
# Local Storage
# ============================================================

LOCAL_STORAGE_DIR=./storage
LOCAL_EXPORT_DIR=./exports

# ============================================================
# Agora Optional
# REALTIME_PROVIDER=agora is strict by default. Missing Agent Studio config is surfaced as an error.
# Browser TTS is used only for browser_tts/mock, or when ALLOW_COACH_FALLBACK=true.
# ============================================================

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
AGORA_AGENT_NAME=
AGORA_AGENT_PIPELINE_ID=
AGORA_AGENT_RTC_UID_BASE=900000
AGORA_AGENT_REMOTE_RTC_UIDS=*
AGORA_AGENT_REGION=
AGORA_AGENT_JOIN_TIMEOUT_SECONDS=10

# ============================================================
# S3/MinIO Optional
# Must only be used through ObjectStoragePort adapter.
# ============================================================

S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_BUCKET_NAME=voiceturk
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000
S3_SECURE=false
S3_PRESIGNED_EXPIRE_SECONDS=900

# FastCheck v2 deterministic thresholds
FAST_CHECK_MIN_DURATION_MS=900
FAST_CHECK_MAX_DURATION_MS=15000
FAST_CHECK_MIN_RMS_DBFS=-45
FAST_CHECK_MAX_RMS_DBFS=-8
FAST_CHECK_MIN_PEAK_DBFS=-35
FAST_CHECK_CLIPPING_RATIO_MAX=0.02
FAST_CHECK_SILENCE_RATIO_MAX=0.65
FAST_CHECK_SPEECH_RATIO_MIN=0.30
FAST_CHECK_LEADING_SILENCE_MAX_MS=1200
FAST_CHECK_TRAILING_SILENCE_MAX_MS=1800
FAST_CHECK_MIN_FILE_SIZE_BYTES=1000
FAST_CHECK_TIMEOUT_SECONDS=15

# ============================================================
# Solana Optional
# Must only be used through ProofProviderPort adapter.
# Dataset Builder must not import Solana directly.
# ============================================================

SOLANA_RPC_URL=
SOLANA_WALLET_PRIVATE_KEY=

# ============================================================
# LLM/ASR Optional
# FastCheck must not require LLM.
# DeepCheck may use these only through ports.
# ============================================================

OPENAI_API_KEY=
WHISPER_PROVIDER=mock
