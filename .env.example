# ============================================================
# VoiceTurk MVP Environment
# ============================================================

APP_ENV=development
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# ============================================================
# Database
# MVP default should work locally without external services.
# Codex may upgrade to Postgres later, but must keep local fallback.
# ============================================================

DATABASE_URL=sqlite+aiosqlite:///./voiceturk.db

# ============================================================
# Provider Switches
# External integrations must go through ports/adapters.
# The MVP must run even when Agora/Solana/S3/ASR/LLM/Redis are disabled.
# ============================================================

OBJECT_STORAGE_PROVIDER=local
REALTIME_PROVIDER=browser_tts
PROOF_PROVIDER=local_hash
FAST_CHECK_PROVIDER=rule_based
DEEP_CHECK_PROVIDER=mock
ASR_PROVIDER=mock
LLM_FEEDBACK_PROVIDER=template
QUEUE_PROVIDER=background_tasks

# ============================================================
# Local Storage
# ============================================================

LOCAL_STORAGE_DIR=./storage
LOCAL_EXPORT_DIR=./exports

# ============================================================
# Agora Optional
# Frontend should fallback to BrowserTTS when this is empty.
# ============================================================

NEXT_PUBLIC_AGORA_APP_ID=
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ============================================================
# S3/MinIO Optional
# Must only be used through ObjectStoragePort adapter.
# ============================================================

S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PUBLIC_BASE_URL=

# ============================================================
# Solana Optional
# Must only be used through ProofProviderPort adapter.
# Dataset Builder must not import Solana directly.
# ============================================================

SOLANA_RPC_URL=
SOLANA_WALLET_PRIVATE_KEY=

# ============================================================
# LLM/ASR Optional
# FastCheck must not require LLM.
# DeepCheck may use these only through ports.
# ============================================================

OPENAI_API_KEY=
WHISPER_PROVIDER=mock
